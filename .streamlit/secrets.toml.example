# Copy to .streamlit/secrets.toml and add your key to enable the live "Learn more" assistant.
# Never commit the real secrets.toml. Synthetic-data testing only.
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: override the model and effort. Default is claude-opus-4-8 at "medium" effort
# (adaptive thinking on, but kept brief for a short grounded answer).
#   VMP_AI_MODEL  = "claude-sonnet-4-6"   # cheaper/faster; also effort-capable
#   VMP_AI_EFFORT = "low"                 # low | medium | high | max
# An override must be an effort-capable, sampling-param-free model (Opus 4.6/4.7/4.8 or
# Sonnet 4.6). Haiku 4.5 and Sonnet 4.5 reject the effort param and will fall back to
# curated text. Do NOT add a temperature — Opus 4.7/4.8 reject sampling params with a 400.
